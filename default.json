{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended", "abandonments:recommended", "helpers:pinGitHubActionDigests"],
	"schedule": ["* 21-23 * * 7", "* 0-16 * * 1" ],
	"prHourlyLimit": 16,
	"prConcurrentLimit": 4,
	"commitMessagePrefix": "⬆️ ",
	"commitBody": "{{#if logJSON.hasReleaseNotes}}{{#each logJSON.versions as |release|}}{{# if release.releaseNotes}}##### [`v{{{release.version}}}`]({{{release.releaseNotes.url}}})\n\n{{{release.releaseNotes.body}}}{{/if}}{{/each}}{{/if}}",
	"rangeStrategy": "bump",
	"abandonmentThreshold": "2 years",
	"minimumReleaseAge": "7 days",
	"internalChecksFilter": "strict",
	"dependencyDashboard": true,
	"packageRules": [
		{
			"groupName": "Playwright",
			"description": "Group playwright docker image & npm package",
			"automerge": true,
			"matchPackageNames": [
				"@playwright/test",
				"mcr.microsoft.com/playwright",
				"ghcr.io/gwennlbh/playwright-bun",
				"docker.io/gwennlbh/playwright-bun",
				"gwennlbh/playwright-bun"
			],
		},
		{
			"groupName": "Wuchale",
			"description": "Group wuchale with its other packages",
			"matchPackageNames": [
				"wuchale",
				"@wuchale/*"
			]
		},
		{
			"groupName": "Gradle",
			"description": "Group gradle wrapper and com.android.tools.build:gradle",
			"matchPackageNames": [
				"com.android.tools.build:gradle",
				"gradle"
			]
		}
	]
}
